generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum AssetCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  TRIAGE
  INVESTIGATING
  CONTAINED
  RESOLVED
}

model User {
  id           Int             @id @default(autoincrement())
  email        String          @unique
  passwordHash String
  role         Role            @default(CLIENT)
  createdAt    DateTime        @default(now())
  tickets      Ticket[]
  messages     TicketMessage[]
  payments     Payment[]
  customerId   Int?
  customer     Customer?       @relation(fields: [customerId], references: [id])
  incidents    Incident[]      @relation("IncidentAnalyst")
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  active      Boolean  @default(true)
  category    String   @default("Managed Security")
  tier        String   @default("Business")
  slaHours    Int      @default(4)
  customers   Customer[]
}

model Ticket {
  id        Int             @id @default(autoincrement())
  userId    Int
  subject   String
  status    String
  priority  String
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id])
  messages  TicketMessage[]
}

model TicketMessage {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  senderId  Int
  content   String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  sender    User     @relation(fields: [senderId], references: [id])
}

model Payment {
  id            Int      @id @default(autoincrement())
  userId        Int
  amount        Float
  currency      String
  status        String
  last4         String
  brand         String
  transactionId String   @unique
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model SecurityEvent {
  id        Int      @id @default(autoincrement())
  type      String
  severity  String
  sourceIp  String
  endpoint  String
  payload   String
  action    String
  timestamp DateTime @default(now())
  metadata  String?
}

model Customer {
  id             Int        @id @default(autoincrement())
  name           String
  industry       String
  region         String
  securityTier   String
  createdAt      DateTime   @default(now())
  primaryServiceId Int?
  primaryService Service?   @relation(fields: [primaryServiceId], references: [id])
  users          User[]
  assets         Asset[]
  incidents      Incident[]
}

model Asset {
  id            Int              @id @default(autoincrement())
  customerId    Int
  hostname      String
  assetType     String
  environment   String
  criticality   AssetCriticality
  region        String
  exposureScore Int
  createdAt     DateTime         @default(now())
  customer      Customer         @relation(fields: [customerId], references: [id])
  incidents     Incident[]
}

model Incident {
  id             Int              @id @default(autoincrement())
  customerId     Int
  assetId        Int
  analystId      Int?
  title          String
  vector         String
  severity       IncidentSeverity
  status         IncidentStatus
  sourceIp       String
  sourceCountry  String
  attackSurface  String
  timelineSlot   Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  customer       Customer         @relation(fields: [customerId], references: [id])
  asset          Asset            @relation(fields: [assetId], references: [id])
  analyst        User?            @relation("IncidentAnalyst", fields: [analystId], references: [id])
}
