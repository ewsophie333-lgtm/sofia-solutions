{
  "name": "sofia-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend academico de Sofia Solutions con modos vulnerable y secure.",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:vuln": "cmd /V /C \"set APP_MODE=vulnerable&& tsx watch src/server.ts\"",
    "dev:secure": "cmd /V /C \"set APP_MODE=secure&& tsx watch src/server.ts\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "test:vuln": "tsx tests/test-vuln.ts",
    "test:secure": "tsx tests/test-secure.ts",
    "attack:sqli:vuln": "tsx tests/attack-sqli.ts vulnerable",
    "attack:sqli:secure": "tsx tests/attack-sqli.ts secure",
    "attack:xss:vuln": "tsx tests/attack-xss.ts vulnerable",
    "attack:xss:secure": "tsx tests/attack-xss.ts secure",
    "attack:traversal:vuln": "tsx tests/attack-traversal.ts vulnerable",
    "attack:traversal:secure": "tsx tests/attack-traversal.ts secure",
    "attack:payment:vuln": "tsx tests/attack-payment.ts vulnerable",
    "attack:payment:secure": "tsx tests/attack-payment.ts secure",
    "attack:bruteforce:vuln": "tsx tests/attack-bruteforce.ts vulnerable",
    "attack:bruteforce:secure": "tsx tests/attack-bruteforce.ts secure",
    "services:validate": "tsx tests/validate-services.ts",
    "services:matrix:vuln": "tsx tests/attack-service-matrix.ts vulnerable",
    "services:matrix:secure": "tsx tests/attack-service-matrix.ts secure",
    "attack:all:vuln": "npm run attack:sqli:vuln && npm run attack:xss:vuln && npm run attack:traversal:vuln && npm run attack:payment:vuln",
    "attack:all:secure": "npm run attack:sqli:secure && npm run attack:xss:secure && npm run attack:traversal:secure && npm run attack:payment:secure",
    "attack:defense:vuln": "npm run attack:bruteforce:vuln && npm run services:matrix:vuln",
    "attack:defense:secure": "npm run attack:bruteforce:secure && npm run services:matrix:secure"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.16.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "md5": "^2.3.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "6.16.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
